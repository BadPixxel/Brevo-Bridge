{
    "name":         "badpixxel/brevo-bridge",
    "description":  "Symfony Bundle to Manage Sending User Email via Brevo Transactional API",
    "type":         "symfony-bundle",
    "keywords":     ["Symfony", "Bundle", "Mailer", "PHP", "Sendinblue", "Brevo", "API", "Bridge"],
    "homepage":     "https://www.badpixxel.com",
    "license":      "MIT",
    "prefer-stable": true,
    "minimum-stability": "dev",
    
    "authors": [
        {
            "name": "BadPixxel",
            "email": "eshop.bpaquier@gmail.com"
        }
    ],
    
    "autoload": {
        "psr-4": { "BadPixxel\\BrevoBridge\\": "src" }
    },
    "autoload-dev": {
        "psr-4": { "BadPixxel\\BrevoBridge\\Tests\\": "tests" }
    },
    
    "require": {
        "php":                                          "^8.1",
        "ext-curl":                                     "*",
        "ext-json":                                     "*",

        "symfony/config":                               "^5.4|^6.4|^7.4|^8.0",
        "symfony/dependency-injection":                 "^5.4|^6.4|^7.4|^8.0",
        "symfony/event-dispatcher":                     "^5.4|^6.4|^7.4|^8.0",
        "symfony/options-resolver":                     "^5.4|^6.4|^7.4|^8.0",

        "doctrine/orm":                                 "^2.6|^3.0",
        "doctrine/doctrine-bundle":                     "^2.7|^3.0",

        "twig/extra-bundle":                            "^2.0|^3.0",
        "twig/intl-extra":                              "^2.0|^3.0",

        "getbrevo/brevo-php":                           "^1.0",

        "sonata-project/user-bundle":                   ">4.0",

        "knplabs/knp-time-bundle":                      ">1.0",
        "psr/simple-cache":                             "^1.0"
    },
    
    "require-dev": {
        "badpixxel/php-sdk":                            "^2.0|^3.0",
        "badpixxel/paddock-mysql":                      "dev-main",

        "symfony/http-kernel":                          "^5.4|^6.4|^7.4|^8.0",
        "symfony/twig-bundle":                          "^5.4|^6.4|^7.4|^8.0",
        "symfony/runtime":                              "^5.4|^6.4|^7.4|^8.0",
        "symfony/mailer":                               "^5.4|^6.4|^7.4|^8.0",
        "symfony/phpunit-bridge":                       "^5.4|^6.4|^7.4|^8.0",
        "symfony/debug-bundle":                         "^5.4|^6.4|^7.4|^8.0",
        "symfony/stopwatch":                            "^5.4|^6.4|^7.4|^8.0",
        "symfony/web-profiler-bundle":                  "^5.4|^6.4|^7.4|^8.0",
        "symfony/monolog-bundle":                       "^3.0|^4.0",
        "symfony/flex":                                 "^1.0|^2.0",

        "sonata-project/admin-bundle":                  "^4.0",
        "sonata-project/doctrine-orm-admin-bundle":     "^4.0",
        
        "phpunit/phpunit":                              "^9"
    },

    "config": {
        "allow-plugins": {
            "phpro/grumphp":            true,
            "symfony/runtime":          true,
            "symfony/flex":             true,
            "phpro/grumphp-shim":       true
        }
    },

    "scripts": {
        "auto-scripts": {
            "cache:clear --no-debug": "symfony-cmd",
            "assets:install --relative": "symfony-cmd",
            "doctrine:schema:update --force --complete --no-interaction --no-debug": "symfony-cmd",
            "find var/cache/dev/*.xml -not -name \"testContainer.xml\" | while read -r i; do cp \"$i\" var/cache/dev/testContainer.xml; done": "script"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],

        "post-update-cmd": [
            "@auto-scripts"
        ]
    },

    "archive": {
        "exclude": ["/bin", "/tests"]
    },

    "extra": {
        "public-dir": "tests/public"
    }
}
